#!/usr/bin/env python3

def dms_to_decimal(degrees, minutes, seconds, direction):
    """Convert degrees, minutes, seconds to decimal degrees."""
    decimal = degrees + minutes / 60 + seconds / 3600
    if direction in ('S', 'W'):
        decimal = -decimal
    return decimal

def get_osm_link(lat, lon, zoom=15):
    """Generate an OpenStreetMap link for given coordinates."""
    return f"https://www.openstreetmap.org/?mlat={lat:.6f}&mlon={lon:.6f}#map={zoom}/{lat:.6f}/{lon:.6f}"

def parse_dms_input(prompt):
    """Prompt user for DMS components."""
    print(prompt)
    degrees = float(input("  Degrees: "))
    minutes = float(input("  Minutes: "))
    seconds = float(input("  Seconds: "))
    direction = input("  Direction (N/S for lat, E/W for lon): ").strip().upper()
    return degrees, minutes, seconds, direction

def main():
    import argparse

    parser = argparse.ArgumentParser(
        description="Convert DMS coordinates to decimal degrees and generate an OSM link.",
        epilog="Example: python dms_to_decimal.py 53 55 26 N 1 28 42 W"
    )
    parser.add_argument("lat_deg", nargs="?", type=float, help="Latitude degrees")
    parser.add_argument("lat_min", nargs="?", type=float, help="Latitude minutes")
    parser.add_argument("lat_sec", nargs="?", type=float, help="Latitude seconds")
    parser.add_argument("lat_dir", nargs="?", choices=["N", "S", "n", "s"], help="Latitude direction (N/S)")
    parser.add_argument("lon_deg", nargs="?", type=float, help="Longitude degrees")
    parser.add_argument("lon_min", nargs="?", type=float, help="Longitude minutes")
    parser.add_argument("lon_sec", nargs="?", type=float, help="Longitude seconds")
    parser.add_argument("lon_dir", nargs="?", choices=["E", "W", "e", "w"], help="Longitude direction (E/W)")

    args = parser.parse_args()

    print("=== DMS to Decimal Degrees Converter ===\n")

    # Use command line args if all 8 are provided, otherwise fall back to interactive
    if all(v is not None for v in [args.lat_deg, args.lat_min, args.lat_sec, args.lat_dir,
                                    args.lon_deg, args.lon_min, args.lon_sec, args.lon_dir]):
        lat_d, lat_m, lat_s, lat_dir = args.lat_deg, args.lat_min, args.lat_sec, args.lat_dir.upper()
        lon_d, lon_m, lon_s, lon_dir = args.lon_deg, args.lon_min, args.lon_sec, args.lon_dir.upper()
    else:
        lat_d, lat_m, lat_s, lat_dir = parse_dms_input("Enter Latitude:")
        lon_d, lon_m, lon_s, lon_dir = parse_dms_input("\nEnter Longitude:")

    lat = dms_to_decimal(lat_d, lat_m, lat_s, lat_dir)
    lon = dms_to_decimal(lon_d, lon_m, lon_s, lon_dir)

    print(f"Decimal Degrees:")
    print(f"  Latitude:  {lat:.6f}")
    print(f"  Longitude: {lon:.6f}")
    print(f"\nOpenStreetMap Link:")
    print(f"  {get_osm_link(lat, lon)}")

if __name__ == "__main__":
    main()
